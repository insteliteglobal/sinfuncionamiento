<style>
/* Variables de Color */
:root{
  --primario:#6a00ff;
  --secundario:#00e0ff;
  --oscuro:#0b0b1f;
  --claro:#ffffff;
  --gris:#b0bec5;
  --fondo-card:rgba(255,255,255,.06);
}

/* Reset y Estilos Generales */
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
body{
  background:var(--oscuro);
  color:var(--claro);
  line-height:1.7;
  overflow-x:hidden; /* Previene scroll horizontal */
}

/* TRANSICIONES PARA ANIMACIONES DE SCROLL */
.animate-on-scroll {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}
.animate-on-scroll.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* BARRA SUPERIOR (HEADER) - PARA DESKTOP */
.header-desktop{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  padding:18px 8%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:rgba(11,11,31,.9); /* Fondo semi-transparente */
  backdrop-filter:blur(15px); /* Efecto blur */
  z-index:1000;
  border-bottom: 1px solid rgba(106,0,255,.2); /* Borde sutil */
}

.logo{
  font-size:1.8rem;
  font-weight:800;
  color:var(--claro);
}
.logo span{
  color:var(--secundario); /* El IA en color secundario */
}

.header-desktop nav a{
  color:var(--gris); /* Color de enlaces normal */
  text-decoration:none;
  margin-left:30px;
  font-weight:500;
  font-size:1rem;
  transition:.3s ease;
}
.header-desktop nav a:hover{
  color:var(--secundario); /* Color al pasar el ratón */
}

/* Botón principal en el header (Probar en WhatsApp) */
.btn-header{
  padding:12px 25px;
  border-radius:25px; /* Bordes redondeados */
  background:linear-gradient(90deg,var(--primario),var(--secundario));
  color:white !important; /* Importante para sobrescribir gris */
  font-weight:600;
  transition:.3s ease;
  margin-left: 20px; /* Separación extra */
  box-shadow: 0 5px 15px rgba(0,224,255,.3);
  position: relative; /* Para el efecto de brillo */
  overflow: hidden; /* Asegura que el brillo no se salga */
}
.btn-header::before { /* Efecto de brillo */
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(100deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.4s ease;
}
.btn-header:hover::before {
  left: 100%;
}
.btn-header:hover{
  transform:scale(1.05);
  box-shadow: 0 0 20px rgba(0,224,255,.4);
}

/* OCULTAR HEADER EN MÓVIL */
@media(max-width:768px){
  .header-desktop{display:none;}
}

/* HERO */
.hero{
  position:relative;
  height:70vh; /* Altura reducida pero impactante */
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding-top: 70px; /* Espacio para el header fijo */
}

.hero video{
  position:absolute;
  inset:0; /* Cubre toda la sección */
  width:100%;
  height:100%;
  object-fit:cover;
  filter:brightness(.3); /* Oscurece el video para que el texto resalte */
}

.hero-content{
  z-index:2;
  max-width:900px;
  padding:20px;
}

.hero h1{
  font-size:3.5rem; /* Más grande para impacto */
  font-weight:800;
  background:linear-gradient(90deg,var(--secundario),var(--primario));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  text-shadow: 0 0 20px rgba(106,0,255,.3); /* Sombra sutil */
}

.hero p{
  margin:15px 0 25px;
  color:var(--gris);
  font-size:1.2rem;
  font-weight:300;
}

/* Botones generales (para Hero, CTA, etc.) */
.btn{
  padding:14px 34px;
  border-radius:30px;
  background:linear-gradient(90deg,var(--primario),var(--secundario));
  color:white !important;
  text-decoration:none;
  font-weight:600;
  margin:5px;
  display:inline-block;
  transition:.3s ease;
  box-shadow: 0 5px 20px rgba(0,224,255,.2); /* Sombra atractiva */
}
.btn:hover{
  transform:scale(1.05);
  box-shadow: 0 8px 25px rgba(0,224,255,.4);
}

/* SECCIONES GENERALES */
section{
  padding:100px 10%; /* Espacio vertical generoso */
  position:relative;
  overflow:hidden; /* Para contener animaciones */
}
.titulo{
  text-align:center;
  margin-bottom:60px;
  padding-bottom:20px; /* Espacio debajo del título */
  border-bottom: 1px solid rgba(255,255,255,.1); /* Separador sutil */
}
.titulo h2{
  font-size:2.8rem;
  font-weight:800;
  margin-bottom:15px;
}
.titulo p{
  color:var(--gris);
  font-size:1.1rem;
}

/* Grid para Cards */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:35px;
}

/* Estilo de las Cards */
.card{
  background:var(--fondo-card);
  padding:35px;
  border-radius:22px;
  backdrop-filter:blur(12px);
  transition:.4s cubic-bezier(0.25, 0.8, 0.25, 1); /* Animación suave */
  border: 1px solid rgba(255,255,255,.05); /* Borde delgado */
}
.card:hover{
  transform:translateY(-10px);
  box-shadow:0 15px 40px rgba(0,224,255,.25); /* Sombra más pronunciada */
}
.card h3{
  margin-bottom:15px;
  color:var(--secundario); /* Títulos de card en secundario */
  font-size:1.4rem;
}
.card p{
  color:var(--gris);
  font-size:1rem;
}

/* SECCIÓN CÓMO FUNCIONA */
.card.como-funciona-item{
  text-align:center;
  background: linear-gradient(145deg, #0a0a1f, #12123a); /* Gradiente en las cards */
  border: 1px solid rgba(0,224,255,.1);
}
.card.como-funciona-item h3{
  font-size:1.8rem;
  color:var(--secundario);
  position:relative;
  display:inline-block;
  margin-bottom:20px;
}
.card.como-funciona-item h3::after{
  content:'';
  position:absolute;
  bottom:-5px;
  left:50%;
  transform:translateX(-50%);
  width:40px;
  height:4px;
  background:linear-gradient(90deg,var(--primario),var(--secundario));
  border-radius:2px;
}
.card.como-funciona-item p{
  font-size:1rem;
  color:var(--gris);
}

/* SECCIÓN DEMO CHAT */
#demo-chat .card{
  background:rgba(26,26,58,.5); /* Fondo oscuro para el chat */
  border: 1px solid rgba(0,224,255,.1);
}
#demo-chat .card p{
  margin-bottom:10px;
  font-size:0.95rem;
  color:#e0e0e0;
}
#demo-chat .card p:last-of-type{
  margin-bottom:0;
}
#demo-chat .card strong{
  color:var(--primario);
}
#demo-chat .card h3{
  color:var(--secundario);
  font-size:1.4rem;
  margin-bottom:15px;
}

/* SECCIÓN PLANES */
.precio{
  font-size:2.5rem;
  font-weight:800;
  color:var(--secundario);
  margin:15px 0;
}
.card.plan-card h3{
  color:var(--claro);
}
.card.plan-card p{
  margin-bottom:20px;
  font-size:1rem;
  color:var(--gris);
}
.card.plan-card ul {
  list-style: none;
  padding: 0;
  margin-bottom: 25px;
  text-align: left; /* Alineación a la izquierda para la lista */
  color: var(--gris);
}
.card.plan-card li {
  margin-bottom: 8px;
  font-size: 0.95rem;
  display: flex;
  align-items: center;
}
.card.plan-card li::before {
  content: '✅'; /* Emoji de check */
  color: var(--secundario);
  margin-right: 10px;
  font-size: 1.1em;
}

/* SECCIÓN DE TESTIMONIOS */
.testimonio-text{
  font-style:italic;
  font-size:1.1rem;
  color:var(--gris);
  margin-bottom:15px;
}
.testimonio-autor{
  font-weight:600;
  color:var(--claro);
}

/* SECCIÓN DE CONFIANZA / LOGOS */
.icon-list{
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:25px;
}
.icon-card{
  background:var(--fondo-card);
  padding:20px 30px;
  border-radius:15px;
  backdrop-filter:blur(10px);
  font-size:1.1rem;
  font-weight:600;
  color:var(--gris);
  border: 1px solid rgba(255,255,255,.05);
  transition:.3s;
}
.icon-card:hover{
  transform:translateY(-5px);
  box-shadow:0 10px 25px rgba(0,224,255,.2);
  color:var(--secundario);
}

/* BOTÓN WHATSAPP FLOTANTE ADICIONAL */
.whatsapp-float {
  position: fixed;
  bottom: 100px; /* Ajusta esta posición si interfiere con el menú tortuga */
  right: 30px;
  z-index: 998; /* Debajo del menú tortuga */
  display: block;
}
.whatsapp-float a {
  width: 70px;
  height: 70px;
  background: linear-gradient(90deg, #25d366, #128c7e); /* Verde WhatsApp */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 25px rgba(37, 211, 102, 0.7);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.whatsapp-float a:hover {
  transform: scale(1.1);
  box-shadow: 0 0 35px rgba(37, 211, 102, 1);
}
.whatsapp-float svg {
  width: 35px;
  height: 35px;
  fill: white;
}

/* MENÚ TORTUGA (SOLO MÓVIL) */
.menu-tortuga{
  position:fixed;
  bottom:30px;
  right:30px;
  z-index:999; /* Encima de todo */
  display:block;
}

@media(min-width:769px){
  .menu-tortuga{display:none;} /* Oculto en desktop */
}

.menu-btn{
  width:70px;
  height:70px;
  border-radius:50%;
  background:linear-gradient(90deg,var(--primario),var(--secundario));
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:30px;
  cursor:pointer;
  box-shadow: 0 0 25px rgba(106,0,255,.5);
  transition:.3s;
}
.menu-btn:hover{
  transform:scale(1.1);
  box-shadow: 0 0 35px rgba(0,224,255,.7);
}

.menu-items{
  position:absolute;
  bottom:85px; /* Posición por encima del botón */
  right:10px;
  display:none; /* Inicialmente oculto */
  flex-direction:column;
  gap:12px;
  animation: fadeIn 0.5s ease-out forwards; /* Animación de aparición */
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.menu-items a{
  background:rgba(26,26,58,.8); /* Fondo oscuro y transparente */
  padding:15px 25px;
  border-radius:25px;
  color:white;
  text-decoration:none;
  font-size:15px;
  text-align:center;
  font-weight:500;
  transition:.3s;
  box-shadow: 0 5px 15px rgba(0,0,0,.2);
}
.menu-items a:hover{
  background:linear-gradient(90deg,var(--primario),var(--secundario));
  color:white;
  transform:translateX(-5px);
}

/* FOOTER */
footer{
  background:linear-gradient(180deg, rgba(11,11,31,.8), #050514); /* Gradiente suave */
  padding:70px 10%;
  text-align:center;
  color:var(--gris);
  font-size:0.95rem;
  border-top: 1px solid rgba(106,0,255,.2);
}
footer p{
