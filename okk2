}
footer a{
  color:var(--secundario);
  text-decoration:none;
  transition:.3s;
}
footer a:hover{
  text-decoration:underline;
}
/* 🔥 Alinear y bajar botones en planes */
.card.plan-card{
  display:flex;
  flex-direction:column;
}

.card.plan-card .btn{
  margin-top:auto;
}
</style>
</head>

